TOGGL_API_TOKEN = os.getenv('TOGGL_API_TOKEN', '06651f8178d17463025b96182908185d')
WORKSPACE_ID = os.getenv('TOGGL_WORKSPACE_ID', '4682110')
USER_AGENT = os.getenv('TOGGL_USER_AGENT', 'olejon@google.com')
SPREADSHEET_ID = os.getenv('SPREADSHEET_ID', '1EjyuryS44AXzi6UQwS0qkY4X1YoOjfke3Zdau7-23qs')
SHEET_NAME = os.getenv('SHEET_NAME', 'Daily_Log_Raw')
SERVICE_ACCOUNT_FILE = os.getenv('SERVICE_ACCOUNT_FILE', 'service_account.json')
REQUEST_TIMEOUT = int(os.getenv('REQUEST_TIMEOUT', '30'))
TOGGL_TIMEZONE = os.getenv('TOGGL_TIMEZONE', 'Asia/Almaty')
# ==========================================


COLUMN_MAP = {
    ('LIFE OPS', 'admin'): 'Life Ops admin',
    ('LIFE OPS', 'learn'): 'Life Ops learn',
    ('LIFE OPS', 'production'): 'Life Ops production',

    ('SPORT AND HEALTH', 'admin'): 'SH admin',
    ('SPORT AND HEALTH', 'learn'): 'SH learn',
    ('SPORT AND HEALTH', 'production'): 'SH production',

    ('OT', 'admin'): 'OT admin',
    ('OT', 'learn'): 'OT learn',
    ('OT', 'production'): 'OT production',

    ('FINANCE AND CAREER', 'admin'): 'FC admin',
    ('FINANCE AND CAREER', 'learn'): 'FC learn',
    ('FINANCE AND CAREER', 'production'): 'FC production',

    ('ENGLISH', 'admin'): 'Eng admin',
    ('ENGLISH', 'learn'): 'Eng learn',
    ('ENGLISH', 'production'): 'Eng production',

    ('CONTRIBUTION', 'admin'): 'Contribution',
    ('CONTRIBUTION', 'learn'): 'Contribution',
    ('CONTRIBUTION', 'production'): 'Contribution',

    ('ROUTINE', 'admin'): 'Routine',
    ('ROUTINE', 'learn'): 'Routine',
    ('ROUTINE', 'production'): 'Routine',
}


def parse_input_date(date_str: str) -> str:
    """
    Нормализует входную дату.

    Поддерживает:
    - ДД.ММ.ГГГГ
    - today
    - yesterday

    Возвращает:
        строку в формате ДД.ММ.ГГГГ

    Исключения:
        ValueError — если формат некорректный
    """

    value = date_str.strip().lower()

    if value == 'today':
        return datetime.now().strftime('%d.%m.%Y')

    if value == 'yesterday':
        return (datetime.now() - timedelta(days=1)).strftime('%d.%m.%Y')

    try:
        parsed = datetime.strptime(date_str, '%d.%m.%Y')
        return parsed.strftime('%d.%m.%Y')
    except ValueError as exc:
        raise ValueError(
            'Неверный формат даты. Используй ДД.ММ.ГГГГ, например: 28.02.2026'
        ) from exc


def make_auth() -> HTTPBasicAuth:
    return HTTPBasicAuth(TOGGL_API_TOKEN, 'api_token')


def safe_get(url: str, *, params=None):
    """
    Универсальный wrapper для HTTP-запросов к Toggl API.

    Делает:
    - GET-запрос с авторизацией
    - обрабатывает типовые ошибки API
    - возвращает response при успешном статусе

    Обрабатываемые ошибки:
    - 401: неверный API токен
    - 402: endpoint недоступен (например, платный API)
    - 403: нет доступа
    - 429: превышен rate limit

    Исключения:
        Exception с подробным описанием ошибки
    """

    response = requests.get(
        url,
        params=params,
        auth=make_auth(),
        timeout=REQUEST_TIMEOUT,
        headers={'Content-Type': 'application/json'},
    )

    if response.status_code == 402:
        raise Exception(
            'Toggl вернул 402 Payment Required. '
            'Это означает, что текущий endpoint недоступен для вашего workspace. '
            f'URL: {response.url}\n'
            f'Body: {response.text}'
        )

    if response.status_code == 401:
        raise Exception(
            'Toggl вернул 401 Unauthorized. Проверь TOGGL_API_TOKEN. '
            f'URL: {response.url}\nBody: {response.text}'
        )

    if response.status_code == 403:
        raise Exception(
            'Toggl вернул 403 Forbidden. У пользователя нет доступа к ресурсу. '
            f'URL: {response.url}\nBody: {response.text}'
        )

    if response.status_code == 429:
        raise Exception(
            'Toggl вернул 429 Too Many Requests. Слишком много запросов за короткое время. '
            f'URL: {response.url}\nBody: {response.text}'
        )

    try:
        response.raise_for_status()
    except requests.HTTPError as exc:
        raise Exception(
            f'Ошибка запроса к Toggl: HTTP {response.status_code}\n'
            f'URL: {response.url}\n'
            f'Body: {response.text}'
        ) from exc

    return response


def parse_toggl_datetime(value: str) -> datetime:
    """
    Парсит datetime из Toggl в aware-datetime.

    Поддерживает форматы:
    - 2026-04-16T23:59:00Z
    - 2026-04-16T23:59:00+00:00
    """

    if not value:
        raise ValueError('Пустое значение datetime от Toggl')

    if value.endswith('Z'):
        value = value[:-1] + '+00:00'

    return datetime.fromisoformat(value)


def get_local_day_bounds(sheet_date: str, tz_name: str = TOGGL_TIMEZONE):
    """
    Возвращает границы локальных суток и их UTC-представление.

    Возвращает:
        tuple(
            local_start,
            local_end,
            utc_start,
            utc_end
        )
    """

    tz = ZoneInfo(tz_name)

    local_start = datetime.strptime(sheet_date, '%d.%m.%Y').replace(
        hour=0, minute=0, second=0, microsecond=0, tzinfo=tz
    )
    local_end = local_start + timedelta(days=1)

    utc_start = local_start.astimezone(timezone.utc)
    utc_end = local_end.astimezone(timezone.utc)

    return local_start, local_end, utc_start, utc_end


def clip_entry_to_local_day(entry: dict, sheet_date: str, tz_name: str = TOGGL_TIMEZONE) -> int:
    """
    Возвращает длительность записи, которая реально попадает
    в локальные сутки sheet_date.

    Логика:
    - берём интервал записи [start, stop)
    - берём интервал локальных суток, переведённый в UTC
    - считаем пересечение этих двух интервалов

    Возвращает:
        int — длительность в миллисекундах
    """

    _, _, utc_day_start, utc_day_end = get_local_day_bounds(sheet_date, tz_name)

    start_raw = entry.get('start')
    stop_raw = entry.get('stop')

    if not start_raw or not stop_raw:
        return 0

    start_dt = parse_toggl_datetime(start_raw).astimezone(timezone.utc)
    stop_dt = parse_toggl_datetime(stop_raw).astimezone(timezone.utc)

    if stop_dt <= start_dt:
        return 0

    overlap_start = max(start_dt, utc_day_start)
    overlap_end = min(stop_dt, utc_day_end)

    if overlap_end <= overlap_start:
        return 0

    overlap_seconds = (overlap_end - overlap_start).total_seconds()
    return int(overlap_seconds * 1000)


def get_time_entries(sheet_date: str):
    """
    Получает список time entries за конкретный локальный день
    через Toggl Track API v9.

    Важно:
    - диапазон суток считается в локальном timezone
    - в API отправляется уже переведённый диапазон в UTC
    - meta=true добавляет project_name и tags

    Возвращает:
        list[dict] — список записей Toggl

    Исключения:
        Exception — если формат ответа неожиданный
    """

    _, _, utc_start, utc_end = get_local_day_bounds(sheet_date)

    url = 'https://api.track.toggl.com/api/v9/me/time_entries'
    params = {
        'start_date': utc_start.isoformat().replace('+00:00', 'Z'),
        'end_date': utc_end.isoformat().replace('+00:00', 'Z'),
        'meta': 'true',
    }

    response = safe_get(url, params=params)
    payload = response.json()

    if not isinstance(payload, list):
        raise Exception(
            'Ожидался список time entries от Toggl, но пришёл другой формат. '
            f'Body: {payload}'
        )

    return payload


def normalize_report(items, sheet_date: str):
    """
    Приводит ответ Track API v9 к внутреннему формату.

    Зачем:
    - унифицировать данные под summarize()
    - абстрагироваться от структуры API
    - корректно учитывать записи, пересекающие границу суток

    Преобразования:
    - длительность считается по пересечению записи с локальными сутками
    - project_name → project
    - tags остаются как есть

    Возвращает:
        {
            "data": [
                {
                    "project": str,
                    "tags": list[str],
                    "dur": int (ms)
                }
            ]
        }
    """

    normalized = []

    for entry in items:
        dur_ms = clip_entry_to_local_day(entry, sheet_date)

        if dur_ms <= 0:
            continue

        project_name = entry.get('project_name') or ''
        tags = entry.get('tags') or ['']

        normalized.append({
            'project': project_name,
            'tags': tags,
            'dur': dur_ms,
        })

    return {'data': normalized}


def get_report(sheet_date: str):
    items = get_time_entries(sheet_date)
    return normalize_report(items, sheet_date)


def summarize(report_data):
    """
    Агрегирует время по (project, tag).

    Логика:
    - берётся только первый тег записи
    - суммируется длительность
    - переводится в минуты

    Параметры:
        report_data: dict (результат normalize_report)

    Возвращает:
        dict:
            {
                (project, tag): minutes
            }
    """

    result = {}

    for entry in report_data.get('data', []):
        project = entry.get('project') or ''
        tags = entry.get('tags') or ['']
        tag = tags[0] if tags else ''

        dur_ms = entry.get('dur', 0) or 0
        duration_seconds = dur_ms / 1000

        key = (project, tag)
        result[key] = result.get(key, 0) + duration_seconds

    return {k: round(v / 60) for k, v in result.items()}


def connect_sheet():
    scopes = [
        'https://www.googleapis.com/auth/spreadsheets',
        'https://www.googleapis.com/auth/drive'
    ]

    creds = Credentials.from_service_account_file(
        SERVICE_ACCOUNT_FILE,
        scopes=scopes
    )

    client = gspread.authorize(creds)
    spreadsheet = client.open_by_key(SPREADSHEET_ID)
    return spreadsheet.worksheet(SHEET_NAME)


def find_row_by_date(ws, date_str: str):
    dates = ws.col_values(1)

    for i, value in enumerate(dates, start=1):
        if value.strip() == date_str:
            return i

    return None


def normalize_header(value: str) -> str:
    return ' '.join(value.replace('\n', ' ').split()).strip().lower()


def update_sheet(sheet_date: str, data):
    """
    Записывает агрегированные данные в Google Sheets.

    Этапы:
    1. Находит строку по дате
    2. Читает заголовки
    3. Нормализует названия колонок
    4. Маппит (project, tag) → колонка
    5. Агрегирует значения по колонкам
    6. Записывает значения в таблицу

    Особенности:
    - несколько источников могут попадать в одну колонку
    - unmapped данные выводятся в консоль
    - запись идёт по ячейкам (update_cell)

    Исключения:
        Exception — если дата не найдена в таблице
    """

    ws = connect_sheet()

    row = find_row_by_date(ws, sheet_date)
    if not row:
        raise Exception(f'Дата {sheet_date} не найдена в листе {SHEET_NAME}')

    headers = ws.row_values(1)
    normalized_headers = {
        normalize_header(header): idx + 1
        for idx, header in enumerate(headers)
    }

    unmapped = []
    aggregated_by_column = {}

    for (project, tag), minutes in data.items():
        col_name = COLUMN_MAP.get((project, tag))

        if not col_name:
            unmapped.append((project, tag, minutes))
            continue

        normalized_col_name = normalize_header(col_name)

        if normalized_col_name not in normalized_headers:
            unmapped.append((project, tag, minutes))
            continue

        aggregated_by_column[normalized_col_name] = (
                aggregated_by_column.get(normalized_col_name, 0) + minutes
        )

    updates_count = 0

    for normalized_col_name, total_minutes in aggregated_by_column.items():
        col_index = normalized_headers[normalized_col_name]
        ws.update_cell(row, col_index, total_minutes)
        updates_count += 1

    print(f'Updated {updates_count} cells for {sheet_date}')

    if unmapped:
        print('Не сопоставлены следующие категории:')
        for project, tag, minutes in unmapped:
            print(f'  {project}: {tag} = {minutes}')


def print_summary(data):
    """
    Выводит агрегированный отчёт в консоль.

    Показывает:
    - минуты по проектам и тегам
    - общее время в формате HH:MM:SS

    Особенности:
    - сначала выводятся ключевые проекты (key_order)
    - затем остальные (если есть)
    """

    key_order = [
        'LIFE OPS',
        'SPORT AND HEALTH',
        'OT',
        'FINANCE AND CAREER',
        'ENGLISH',
        'CONTRIBUTION',
        'ROUTINE'
    ]

    total_seconds = 0

    for project in key_order:
        for (p, tag), minutes in data.items():
            if p == project:
                print(f"{p}: {tag} = {minutes}")
                total_seconds += minutes * 60

    other_keys = [
        ((p, tag), minutes)
        for (p, tag), minutes in data.items()
        if p not in key_order
    ]
    for (p, tag), minutes in sorted(other_keys):
        print(f"{p or '[NO PROJECT]'}: {tag or '[NO TAG]'} = {minutes}")
        total_seconds += minutes * 60

    hours = int(total_seconds // 3600)
    minutes = int((total_seconds % 3600) // 60)
    seconds = int(total_seconds % 60)

    print(f"{hours:02}:{minutes:02}:{seconds:02}")


def main():
    """
    Точка входа в программу.

    Последовательность:
    1. Парсинг аргументов CLI
    2. Нормализация даты
    3. Получение данных из Toggl
    4. Агрегация
    5. Вывод в консоль
    6. Запись в Google Sheets
    """

    parser = argparse.ArgumentParser(
        description='Загружает time entries из Toggl за дату и записывает их в Google Sheets.'
    )

    parser.add_argument(
        'date',
        type=str,
        help='Дата в формате ДД.ММ.ГГГГ (например 28.02.2026)'
    )

    args = parser.parse_args()

    sheet_date = parse_input_date(args.date)

    report = get_report(sheet_date)
    summary = summarize(report)

    print_summary(summary)
    update_sheet(sheet_date, summary)


if __name__ == '__main__':
    main()
